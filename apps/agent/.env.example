# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://biagent:biagent@localhost/biagent

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Google OAuth (Sheets + Drive) ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Scopes needed: spreadsheets.readonly, drive.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SHEETS_REDIRECT_URI=http://localhost:8000/v1/oauth/google-sheets/callback

# ── Google OAuth (Gmail) ──────────────────────────────────────────────────────
# Uses the same GCP client ID/secret above; separate redirect URI only.
# Scope: gmail.readonly
# WARNING: gmail.readonly is a sensitive scope — keep GCP project in Testing
# mode (max 100 users) until you complete Google's OAuth verification process.
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:8000/v1/oauth/gmail/callback

# ── Notion ────────────────────────────────────────────────────────────────────
# Shared integration key (dev fallback — users connect via OAuth in prod):
NOTION_API_KEY=secret_...
# OAuth app credentials (create at https://www.notion.so/my-integrations):
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/v1/oauth/notion/callback

# ── Security ──────────────────────────────────────────────────────────────────
# Exactly 32 characters — used for Fernet encryption of stored credentials.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32)[:32])"
CREDENTIAL_ENCRYPTION_KEY=change-me-to-a-32-char-secret!!

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Your Clerk frontend API domain, e.g. clerk.your-domain.com
# Found at: Clerk Dashboard → API Keys → Advanced
CLERK_FRONTEND_API=

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ── Observability ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bi-agent-dev
# LANGCHAIN_TRACING_V2=true

# ── n8n Automation ─────────────────────────────────────────────────────────────
# Start n8n: docker run -it --rm -p 5678:5678 n8nio/n8n
# Get API key: n8n Settings → API Keys → Create
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=change-me-webhook-secret
